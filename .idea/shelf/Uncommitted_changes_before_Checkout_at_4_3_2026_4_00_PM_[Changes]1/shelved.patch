+package com.example.fruit_app;
+
+import android.content.Intent;
+import android.os.Bundle;
+import android.widget.ArrayAdapter;
+import android.widget.ListView;
+import android.widget.TextView;
+
+import androidx.appcompat.app.AppCompatActivity;
+
+import com.example.fruit_app.database.AppDatabase;
+import com.example.fruit_app.entity.Product;
+
+import java.util.ArrayList;
+import java.util.List;
+
+public class ProductListActivity extends AppCompatActivity {
+
+    private ListView listView;
+    private TextView titleTextView;
+    private AppDatabase database;
+    private List<Product> productList;
+    private ArrayAdapter<String> adapter;
+    private int categoryId = -1;
+    private String categoryName = "";
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        setContentView(R.layout.activity_product_list);
+
+        listView = findViewById(R.id.productListView);
+        titleTextView = findViewById(R.id.titleTextView);
+        database = AppDatabase.getDatabase(this);
+
+        // Kiểm tra nếu có categoryId từ intent
+        Intent intent = getIntent();
+        categoryId = intent.getIntExtra("category_id", -1);
+        categoryName = intent.getStringExtra("category_name");
+
+        // Load products
+        new Thread(() -> {
+            if (categoryId != -1) {
+                // Nếu có categoryId, lấy sản phẩm theo category
+                productList = database.productDao().getProductsByCategory(categoryId);
+                runOnUiThread(() -> {
+                    titleTextView.setText("Sản phẩm: " + categoryName);
+                    displayProducts();
+                });
+            } else {
+                // Nếu không có categoryId, lấy tất cả sản phẩm
+                productList = database.productDao().getAllProducts();
+                runOnUiThread(() -> {
+                    titleTextView.setText("Danh Sách Sản Phẩm");
+                    displayProducts();
+                });
+            }
+        }).start();
+    }
+
+    private void displayProducts() {
+        List<String> productNames = new ArrayList<>();
+        for (Product product : productList) {
+            productNames.add(product.name + " - " + String.format("%.0f VND", product.price));
+        }
+
+        adapter = new ArrayAdapter<>(this, android.R.layout.simple_list_item_1, productNames);
+        listView.setAdapter(adapter);
+
+        listView.setOnItemClickListener((parent, view, position, id) -> {
+            Product selectedProduct = productList.get(position);
+            Intent intent = new Intent(ProductListActivity.this, ProductDetailActivity.class);
+            intent.putExtra("product_id", selectedProduct.id);
+            intent.putExtra("product_name", selectedProduct.name);
+            intent.putExtra("product_description", selectedProduct.description);
+            intent.putExtra("product_price", selectedProduct.price);
+            startActivity(intent);
+        });
+    }
+}
